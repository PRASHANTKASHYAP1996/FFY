rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    function isMe(userId) {
      return signedIn() && uid() == userId;
    }

    function changedKeys() {
      return request.resource.data.diff(resource.data).changedKeys();
    }

    function validRate(rate) {
      return rate is int && rate in [5, 10, 20, 50, 100];
    }

    function isAdminByToken() {
      return signedIn() &&
        (
          request.auth.token.admin == true ||
          request.auth.token.isAdmin == true ||
          request.auth.token.role == "admin"
        );
    }

    function userDoc(userId) {
      return get(/databases/$(database)/documents/users/$(userId));
    }

    function userExists(userId) {
      return exists(/databases/$(database)/documents/users/$(userId));
    }

    function isAdminByUserDoc() {
      return signedIn()
        && userExists(uid())
        && (
          userDoc(uid()).data.admin == true ||
          userDoc(uid()).data.isAdmin == true ||
          userDoc(uid()).data.role == "admin"
        );
    }

    function isAdmin() {
      return isAdminByToken() || isAdminByUserDoc();
    }

    function callDoc(callId) {
      return get(/databases/$(database)/documents/calls/$(callId));
    }

    function callExists(callId) {
      return exists(/databases/$(database)/documents/calls/$(callId));
    }

    function isParticipant(callId) {
      return signedIn() &&
        callExists(callId) &&
        (
          callDoc(callId).data.callerId == uid() ||
          callDoc(callId).data.calleeId == uid()
        );
    }

    function isCallParticipantByResource() {
      return signedIn()
        && (
          resource.data.callerId == uid() ||
          resource.data.calleeId == uid()
        );
    }

    function validStringList(fieldName) {
      return !(fieldName in request.resource.data) ||
        request.resource.data[fieldName] is list;
    }

    function validOptionalString(fieldName) {
      return !(fieldName in request.resource.data) ||
        request.resource.data[fieldName] is string;
    }

    function validOptionalBool(fieldName) {
      return !(fieldName in request.resource.data) ||
        request.resource.data[fieldName] is bool;
    }

    function validCreateUserDoc(userId) {
      return request.resource.data.keys().hasOnly([
          "uid",
          "email",
          "displayName",
          "credits",
          "reservedCredits",
          "earningsCredits",
          "platformRevenueCredits",
          "photoURL",
          "bio",
          "gender",
          "city",
          "state",
          "country",
          "topics",
          "languages",
          "isListener",
          "isAvailable",
          "followersCount",
          "level",
          "listenerRate",
          "following",
          "blocked",
          "fcmTokens",
          "favoriteListeners",
          "activeCallId",
          "ratingAvg",
          "ratingCount",
          "ratingSum",
          "createdAt",
          "lastSeen"
        ])
        && request.resource.data.uid == userId
        && request.resource.data.email is string
        && request.resource.data.displayName is string
        && request.resource.data.credits is int
        && request.resource.data.reservedCredits is int
        && request.resource.data.earningsCredits is int
        && request.resource.data.platformRevenueCredits is int
        && request.resource.data.photoURL is string
        && request.resource.data.bio is string
        && request.resource.data.gender is string
        && request.resource.data.city is string
        && request.resource.data.state is string
        && request.resource.data.country is string
        && request.resource.data.topics is list
        && request.resource.data.languages is list
        && request.resource.data.isListener is bool
        && request.resource.data.isAvailable is bool
        && request.resource.data.followersCount is int
        && request.resource.data.level is int
        && request.resource.data.listenerRate is int
        && validRate(request.resource.data.listenerRate)
        && request.resource.data.following is list
        && request.resource.data.blocked is list
        && request.resource.data.fcmTokens is list
        && request.resource.data.favoriteListeners is list
        && request.resource.data.activeCallId is string
        && request.resource.data.ratingAvg is number
        && request.resource.data.ratingCount is int
        && request.resource.data.ratingSum is int;
    }

    function isAllowedSelfUserUpdate() {
      return changedKeys().hasOnly([
          "displayName",
          "photoURL",
          "bio",
          "gender",
          "city",
          "state",
          "country",
          "topics",
          "languages",
          "isListener",
          "isAvailable",
          "listenerRate",
          "lastSeen",
          "following",
          "blocked",
          "fcmTokens",
          "favoriteListeners"
        ])
        && validOptionalString("displayName")
        && validOptionalString("photoURL")
        && validOptionalString("bio")
        && validOptionalString("gender")
        && validOptionalString("city")
        && validOptionalString("state")
        && validOptionalString("country")
        && validStringList("topics")
        && validStringList("languages")
        && validOptionalBool("isListener")
        && validOptionalBool("isAvailable")
        && (!("listenerRate" in request.resource.data) ||
            validRate(request.resource.data.listenerRate))
        && validStringList("following")
        && validStringList("blocked")
        && validStringList("fcmTokens")
        && validStringList("favoriteListeners");
    }

    function validPublicUserKeys(data) {
      return data.keys().hasOnly([
        "uid",
        "displayName",
        "photoURL",
        "bio",
        "topics",
        "languages",
        "isListener",
        "isAvailable",
        "followersCount",
        "level",
        "listenerRate",
        "ratingAvg",
        "ratingCount",
        "ratingSum",
        "createdAt",
        "lastSeen",
        "lastPublicUpdatedAt"
      ]);
    }

    function validPublicUserShape(data, userId) {
      return data.uid == userId
        && validPublicUserKeys(data)
        && data.displayName is string
        && data.photoURL is string
        && data.bio is string
        && data.topics is list
        && data.languages is list
        && data.isListener is bool
        && data.isAvailable is bool
        && data.followersCount is int
        && data.level is int
        && data.listenerRate is int
        && validRate(data.listenerRate)
        && data.ratingAvg is number
        && data.ratingCount is int
        && data.ratingSum is number
        && (!("createdAt" in data) || data.createdAt == null || data.createdAt is timestamp)
        && (!("lastSeen" in data) || data.lastSeen == null || data.lastSeen is timestamp)
        && (!("lastPublicUpdatedAt" in data) || data.lastPublicUpdatedAt is timestamp);
    }

    function parentSession(sessionId) {
      return get(/databases/$(database)/documents/chat_sessions/$(sessionId));
    }

    function parentSessionExists(sessionId) {
      return exists(/databases/$(database)/documents/chat_sessions/$(sessionId));
    }

    function parentHasValidParticipants(sessionId) {
      return parentSessionExists(sessionId) &&
        parentSession(sessionId).data.speakerId is string &&
        parentSession(sessionId).data.listenerId is string &&
        parentSession(sessionId).data.speakerId != "" &&
        parentSession(sessionId).data.listenerId != "" &&
        parentSession(sessionId).data.speakerId != parentSession(sessionId).data.listenerId;
    }

    function parentSessionMatchesPath(sessionId) {
      return parentHasValidParticipants(sessionId) &&
        sessionId ==
          parentSession(sessionId).data.speakerId + "_" + parentSession(sessionId).data.listenerId;
    }

    function isParticipantInParentSession(sessionId) {
      return signedIn()
        && parentSessionMatchesPath(sessionId)
        && (
          parentSession(sessionId).data.speakerId == uid() ||
          parentSession(sessionId).data.listenerId == uid()
        );
    }

    function validMessageDocShape(data) {
      return data.keys().hasOnly([
          "text",
          "type",
          "senderId",
          "receiverId",
          "createdAt",
          "createdAtMs",
          "seen",
          "seenAt",
          "seenAtMs",
          "systemAction",
          "metadata"
        ])
        && data.text is string
        && data.type is string
        && data.senderId is string
        && data.receiverId is string
        && data.seen is bool
        && (!("createdAt" in data) || data.createdAt is timestamp)
        && (!("createdAtMs" in data) || data.createdAtMs is int)
        && (!("seenAt" in data) || data.seenAt == null || data.seenAt is timestamp)
        && (!("seenAtMs" in data) || data.seenAtMs is int)
        && (!("systemAction" in data) || data.systemAction is string)
        && (!("metadata" in data) || data.metadata is map);
    }

    function senderReceiverMatchParent(sessionId, data) {
      return parentSessionMatchesPath(sessionId) && (
        (
          data.senderId == parentSession(sessionId).data.speakerId &&
          data.receiverId == parentSession(sessionId).data.listenerId
        ) ||
        (
          data.senderId == parentSession(sessionId).data.listenerId &&
          data.receiverId == parentSession(sessionId).data.speakerId
        )
      );
    }

    function validMessageCreate(sessionId) {
      return signedIn()
        && parentSessionMatchesPath(sessionId)
        && validMessageDocShape(request.resource.data)
        && request.resource.data.senderId == uid()
        && request.resource.data.receiverId != uid()
        && senderReceiverMatchParent(sessionId, request.resource.data)
        && (!("systemAction" in request.resource.data) || request.resource.data.systemAction == "")
        && !("metadata" in request.resource.data)
        && request.resource.data.seen == false
        && (!("seenAt" in request.resource.data) || request.resource.data.seenAt == null)
        && (!("seenAtMs" in request.resource.data) || request.resource.data.seenAtMs == 0);
    }

    function validMessageUpdate(sessionId) {
      return signedIn()
        && parentSessionMatchesPath(sessionId)
        && validMessageDocShape(request.resource.data)
        && request.resource.data.senderId == resource.data.senderId
        && request.resource.data.receiverId == resource.data.receiverId
        && request.resource.data.text == resource.data.text
        && request.resource.data.type == resource.data.type
        && (!("createdAt" in resource.data) || request.resource.data.createdAt == resource.data.createdAt)
        && (!("createdAtMs" in resource.data) || request.resource.data.createdAtMs == resource.data.createdAtMs)
        && (!("systemAction" in resource.data) || request.resource.data.systemAction == resource.data.systemAction)
        && (!("metadata" in resource.data) || request.resource.data.metadata == resource.data.metadata)
        && changedKeys().hasOnly([
          "seen",
          "seenAt",
          "seenAtMs"
        ])
        && request.resource.data.seen == true
        && resource.data.seen == false
        && request.resource.data.receiverId == uid()
        && (
          !("seenAt" in request.resource.data) ||
          request.resource.data.seenAt == null ||
          request.resource.data.seenAt is timestamp
        )
        && (
          !("seenAtMs" in request.resource.data) ||
          request.resource.data.seenAtMs is int
        );
    }

    function isChatParticipantByResource() {
      return signedIn()
        && (
          resource.data.speakerId == uid() ||
          resource.data.listenerId == uid()
        );
    }

    function isChatParticipantByPath(sessionId) {
      return signedIn()
        && sessionId is string
        && (
          sessionId.matches('^' + uid() + '_.+$') ||
          sessionId.matches('^.+_' + uid() + r'$')
        );
    }

    function validReviewCreate(reviewId) {
      return signedIn()
        && request.resource.data.keys().hasOnly([
          "callId",
          "reviewerId",
          "reviewedUserId",
          "stars",
          "comment",
          "createdAt"
        ])
        && request.resource.data.reviewerId == uid()
        && request.resource.data.reviewedUserId is string
        && request.resource.data.reviewedUserId != uid()
        && request.resource.data.callId is string
        && callExists(request.resource.data.callId)
        && isParticipant(request.resource.data.callId)
        && callDoc(request.resource.data.callId).data.status == "ended"
        && reviewId == request.resource.data.callId + "_" + uid()
        && request.resource.data.stars is int
        && request.resource.data.stars >= 1
        && request.resource.data.stars <= 5
        && request.resource.data.comment is string;
    }

    function validReportCreate() {
      return signedIn()
        && request.resource.data.keys().hasOnly([
          "reporterId",
          "reportedUserId",
          "callId",
          "reason",
          "createdAt"
        ])
        && request.resource.data.reporterId == uid()
        && request.resource.data.reportedUserId is string
        && request.resource.data.reportedUserId != uid()
        && request.resource.data.callId is string
        && callExists(request.resource.data.callId)
        && isParticipant(request.resource.data.callId)
        && request.resource.data.reason is string
        && request.resource.data.reason.size() > 0;
    }

    function isReportOwnerByResource() {
      return signedIn()
        && (
          resource.data.reporterId == uid() ||
          resource.data.reportedUserId == uid()
        );
    }

    match /users/{userId} {
      allow read: if isMe(userId) || isAdmin();
      allow create: if isMe(userId) && validCreateUserDoc(userId);
      allow update: if isMe(userId) && isAllowedSelfUserUpdate();
      allow delete: if false;
    }

    match /public_users/{userId} {
      allow read: if true;
      allow create, update: if false;
      allow delete: if false;
    }

    match /calls/{callId} {
      allow read: if isAdmin() || isCallParticipantByResource();
      allow create: if false;
      allow update: if isAdmin();
      allow delete: if false;
    }

    match /reviews/{reviewId} {
      allow read: if signedIn();
      allow create: if validReviewCreate(reviewId);
      allow update, delete: if isAdmin();
    }

    match /reports/{reportId} {
      allow read: if isAdmin() || isReportOwnerByResource();
      allow create: if validReportCreate();
      allow update, delete: if isAdmin();
    }

    match /rate_limits/{docId} {
      allow read, write: if false;
    }

    match /wallet_transactions/{txId} {
      allow read: if signedIn() && resource.data.userId == uid();
      allow create, update, delete: if false;
    }

    match /withdrawal_requests/{requestId} {
      allow read: if isAdmin() || (signedIn() && resource.data.userId == uid());
      allow create: if false;
      allow update: if isAdmin();
      allow delete: if false;
    }

    match /payment_orders/{orderId} {
      allow read: if isAdmin() || (signedIn() && resource.data.userId == uid());
      allow create, update, delete: if false;
    }

    match /wallet_locks/{lockId} {
      allow read, write: if false;
    }

    match /admin_logs/{logId} {
      allow read, write: if false;
    }

    match /analytics/{docId} {
      allow read, write: if false;
    }

    match /chat_sessions/{sessionId} {
      allow read: if isAdmin() || isChatParticipantByResource() || isChatParticipantByPath(sessionId);
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isParticipantInParentSession(sessionId) || isAdmin();
        allow create: if validMessageCreate(sessionId);
        allow update: if validMessageUpdate(sessionId);
        allow delete: if false;
      }
    }
  }
}